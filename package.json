{
  "name": "rate-shield",
  "version": "1.0.0",
  "description": "Advanced rate limiting middleware for Express with multiple strategies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
